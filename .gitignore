# =============================================================================
# ChoirManager Backend — .gitignore
# =============================================================================

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Virtual Environments ────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ─── Distribution / Packaging ────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
*.whl
*.manifest
*.spec

# ─── Django ──────────────────────────────────────────────────────────────────
*.log
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_collected/

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─── IDE & Editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Testing & Coverage ─────────────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# ─── Jupyter / IPython ──────────────────────────────────────────────────────
.ipynb_checkpoints

# ─── mypy / type-checking ───────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ─── Docker (local overrides) ───────────────────────────────────────────────
docker-compose.override.yml

# ─── Celery ──────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ─── Misc ────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
